{
  "name": "stateside",
  "version": "1.0.0",
  "private": true,
  "description": "Stateside — American English pronunciation, accent & conversation studio.",
  "scripts": {
    "icons": "python make_icons.py",
    "serve": "npx --yes http-server www -p 8000 -c-1",
    "sync": "cap sync",
    "add:android": "cap add android",
    "add:ios": "cap add ios",
    "open:android": "cap open android",
    "open:ios": "cap open ios"
  },
  "dependencies": {
    "@capacitor-community/speech-recognition": "7.0.1",
    "@capacitor-community/text-to-speech": "8.0.2",
    "@capacitor/android": "8.4.1",
    "@capacitor/core": "8.4.1",
    "@capacitor/ios": "8.4.1"
  },
  "devDependencies": {
    "@capacitor/cli": "8.4.1"
  }
}
